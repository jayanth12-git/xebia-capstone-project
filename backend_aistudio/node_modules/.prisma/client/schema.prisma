// ==================================================================
// AI Clinical Trial Protocol Designer — Prisma Schema
// Educational project (college demo) — NOT for real clinical use
// ==================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------------

enum UserRole {
  ADMIN
  REVIEWER
  RESEARCHER
}

enum ProtocolStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  MINOR_REVISION
  MAJOR_REVISION
  REJECTED
  ARCHIVED
}

enum ProtocolPhase {
  PRECLINICAL
  PHASE_I
  PHASE_II
  PHASE_III
  PHASE_IV
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskCategory {
  SAFETY
  OPERATIONAL
  REGULATORY
  DATA_INTEGRITY
  FINANCIAL
  RECRUITMENT
  OTHER
}

enum AdverseEventSeverity {
  MILD
  MODERATE
  SEVERE
  LIFE_THREATENING
  FATAL
}

enum AdverseEventCausality {
  UNRELATED
  UNLIKELY
  POSSIBLE
  PROBABLE
  DEFINITE
}

enum AdverseEventStatus {
  REPORTED
  UNDER_INVESTIGATION
  RESOLVED
  RESOLVED_WITH_SEQUELAE
  ONGOING
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
  CANCELLED
}

enum ReviewDecision {
  APPROVE
  MINOR_REVISION
  MAJOR_REVISION
  REJECT
  PENDING
}

enum ReportType {
  PROTOCOL_SUMMARY
  RISK_ASSESSMENT
  ADVERSE_EVENT_SUMMARY
  REVIEW_SUMMARY
  FULL_PROTOCOL
}

enum ReportFormat {
  JSON
  PDF_READY
}

// ------------------------------------------------------------------
// USERS
// ------------------------------------------------------------------

model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  password    String
  role        UserRole  @default(RESEARCHER)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  protocolsCreated Protocol[]        @relation("ProtocolCreatedBy")
  protocolVersions ProtocolVersion[] @relation("VersionCreatedBy")
  reviews          Review[]          @relation("ReviewerUser")
  reportsGenerated Report[]          @relation("ReportGeneratedBy")

  @@map("users")
}

// ------------------------------------------------------------------
// PROTOCOLS
// ------------------------------------------------------------------

model Protocol {
  id                String         @id @default(uuid())
  title             String
  studyCode         String         @unique
  phase             ProtocolPhase  @default(PHASE_I)
  status            ProtocolStatus @default(DRAFT)
  therapeuticArea   String?
  sponsor           String?
  condition         String
  objective         String
  inclusionCriteria String?
  exclusionCriteria String?
  studyDesign       String?
  population        Int?
  durationWeeks     Int?
  currentVersion    Int            @default(1)

  createdById String
  createdBy   User   @relation("ProtocolCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  versions       ProtocolVersion[]
  reviews        Review[]
  risks          Risk[]
  adverseEvents  AdverseEvent[]
  milestones     Milestone[]
  checklistItems ChecklistItem[]
  reports        Report[]

  @@index([status])
  @@index([phase])
  @@map("protocols")
}

// ------------------------------------------------------------------
// PROTOCOL VERSIONS (version history / snapshots)
// ------------------------------------------------------------------

model ProtocolVersion {
  id         String   @id @default(uuid())
  protocolId String
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  versionNumber Int
  snapshot      Json // full snapshot of protocol fields at time of versioning
  changeSummary String?

  createdById String
  createdBy   User   @relation("VersionCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@unique([protocolId, versionNumber])
  @@map("protocol_versions")
}

// ------------------------------------------------------------------
// PEER REVIEWS
// ------------------------------------------------------------------

model Review {
  id         String   @id @default(uuid())
  protocolId String
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation("ReviewerUser", fields: [reviewerId], references: [id])

  decision ReviewDecision @default(PENDING)
  comments String?
  score    Int? // optional 0-100 quality score

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([protocolId])
  @@map("reviews")
}

// ------------------------------------------------------------------
// RISK MATRIX
// ------------------------------------------------------------------

model Risk {
  id         String   @id @default(uuid())
  protocolId String
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  title       String
  description String?
  category    RiskCategory @default(OTHER)

  probability Int // 1-5 scale
  impact      Int // 1-5 scale
  riskScore   Int // computed = probability * impact
  riskLevel   RiskLevel // computed from riskScore

  mitigationPlan String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([protocolId])
  @@index([riskLevel])
  @@map("risks")
}

// ------------------------------------------------------------------
// ADVERSE EVENT MONITORING
// ------------------------------------------------------------------

model AdverseEvent {
  id         String   @id @default(uuid())
  protocolId String
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  subjectCode String // pseudonymous/fake subject identifier for demo purposes
  description String
  severity    AdverseEventSeverity  @default(MILD)
  causality   AdverseEventCausality @default(POSSIBLE)
  status      AdverseEventStatus    @default(REPORTED)

  onsetDate    DateTime?
  resolvedDate DateTime?
  reportedBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([protocolId])
  @@index([severity])
  @@map("adverse_events")
}

// ------------------------------------------------------------------
// TIMELINE / MILESTONES
// ------------------------------------------------------------------

model Milestone {
  id         String   @id @default(uuid())
  protocolId String
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  title       String
  description String?
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  order       Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([protocolId])
  @@map("milestones")
}

// ------------------------------------------------------------------
// CHECKLIST MODULE
// ------------------------------------------------------------------

model ChecklistItem {
  id         String   @id @default(uuid())
  protocolId String
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  label       String
  isCompleted Boolean @default(false)
  category    String?
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([protocolId])
  @@map("checklist_items")
}

// ------------------------------------------------------------------
// REPORTS
// ------------------------------------------------------------------

model Report {
  id         String   @id @default(uuid())
  protocolId String
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  type    ReportType
  format  ReportFormat @default(JSON)
  content Json // generated report payload

  generatedById String
  generatedBy   User   @relation("ReportGeneratedBy", fields: [generatedById], references: [id])

  createdAt DateTime @default(now())

  @@index([protocolId])
  @@map("reports")
}

// ------------------------------------------------------------------
// SETTINGS (single-row style app settings, key-value also supported)
// ------------------------------------------------------------------

model Setting {
  id          String  @id @default(uuid())
  key         String  @unique
  value       Json
  description String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("settings")
}
